# Mapbox public access token (create one at https://account.mapbox.com/)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional: a Mapbox Studio style URL. The 2D Streets style is used when omitted.
NEXT_PUBLIC_MAPBOX_STYLE_URL=mapbox://styles/mapbox/streets-v12

# Production origin used for canonical, hreflang, sitemap, and social URLs.
SITE_URL=https://example.com
